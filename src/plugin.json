{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Kentik",
  "id": "kentik-connect-datasource",
  "metrics": true,
  "info": {
    "description": "Visualize and explore Kentik network observability data in Grafana.",
    "author": {
      "name": "Kentik",
      "url": "https://www.kentik.com"
    },
    "keywords": [
      "datasource",
      "kentik",
      "network",
      "flow",
      "SNMP",
      "NMS",
      "observability",
      "traffic"
    ],
    "logos": {
      "small": "img/logo_small.png",
      "large": "img/logo_large.png"
    },
    "links": [
      {"name": "Kentik", "url": "https://www.kentik.com"},
      {"name": "Documentation", "url": "https://kb.kentik.com/docs/apis-overview"},
      {"name": "sponsor", "url": "https://www.kentik.com/get-started/"}
    ],
    "screenshots": [
      {"name": "Query Editor", "path": "img/queryeditor.png"},
      {"name": "Graph Panel", "path": "img/graphedit.png"},
      {"name": "Datasource Configuration", "path": "img/datasourceconfig.png"}
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "routes": [
    {
      "path": "site",
      "method": "*",
      "url": "{{.JsonData.url.v6}}/site",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"},
        {"name": "User-Agent", "content": "kentik-connect-datasource/%VERSION% (region={{.JsonData.region}})"}
      ]
    },
    {
      "path": "user",
      "method": "*",
      "url": "{{.JsonData.url.v6}}/user",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"},
        {"name": "User-Agent", "content": "kentik-connect-datasource/%VERSION% (region={{.JsonData.region}})"}
      ]
    },
    {
      "path": "device",
      "method": "*",
      "url": "{{.JsonData.url.v6}}/device",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"},
        {"name": "User-Agent", "content": "kentik-connect-datasource/%VERSION% (region={{.JsonData.region}})"}
      ]
    },
    {
      "path": "custom_dimensions",
      "method": "*",
      "url": "{{.JsonData.url.v6}}/custom_dimensions",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"},
        {"name": "User-Agent", "content": "kentik-connect-datasource/%VERSION% (region={{.JsonData.region}})"}
      ]
    },
    {
      "path": "saved-filters",
      "method": "*",
      "url": "{{.JsonData.url.v6}}/saved-filters",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"},
        {"name": "User-Agent", "content": "kentik-connect-datasource/%VERSION% (region={{.JsonData.region}})"}
      ]
    },
    {
      "path": "api/v5",
      "method": "*",
      "url": "{{.JsonData.url.v5}}/api/v5",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"},
        {"name": "User-Agent", "content": "kentik-connect-datasource/%VERSION% (region={{.JsonData.region}})"}
      ]
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=11.6.0",
    "plugins": []
  }
}