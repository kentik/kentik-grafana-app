{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Kentik Connect Pro",
  "id": "kentikconnectpro-datasource",
  "metrics": true,
  "backend": true, 
  "info": {
    "description": "",
    "author": {
      "name": "Kentik"
    },
    "keywords": ["datasource"],
    "logos": {
      "small": "img/logo_small.png",
      "large": "img/logo_large.png"
    },
    "links": [],
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "routes": [
    {
      "path": "api/v5/*",
      "method": "*",
      "url": "{{ .jsonData.url }}/api/v5/",
      "headers": [
        {
          "name": "X-CH-Auth-API-Token",
          "content": "{{ .secureJsonData.token }}"
        },
        {
          "name": "X-CH-Auth-Email",
          "content": "{{ .jsonData.email }}"
        }
      ]
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  }
}
