{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Kentik Connect Pro",
  "id": "kentikconnectpro-datasource",
  "metrics": true,
  "info": {
    "description": "",
    "author": {
      "name": "Kentik"
    },
    "keywords": [
      "datasource"
    ],
    "logos": {
      "small": "img/logo_small.png",
      "large": "img/logo_large.png"
    },
    "links": [],
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "routes": [
    {
      "path": "site",
      "method": "*",
      "url": "{{.JsonData.url}}/site",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"}        
      ]
    },
    {
      "path": "user",
      "method": "*",
      "url": "{{.JsonData.url}}/user",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"}        
      ]
    },
    {
      "path": "device",
      "method": "*",
      "url": "{{.JsonData.url}}/device",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"}        
      ]
    },
    {
      "path": "custom_dimensions",
      "method": "*",
      "url": "{{.JsonData.url}}/custom_dimensions",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"}        
      ]
    },
    {
      "path": "saved-filters",
      "method": "*",
      "url": "{{.JsonData.url}}/saved-filters",
      "headers": [
        {"name": "X-CH-Auth-API-Token", "content": "{{.SecureJsonData.token}}"},
        {"name": "X-CH-Auth-Email", "content": "{{.JsonData.email}}"},
        {"name": "Accept", "content": "application/json"}        
      ]
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  }
}